#!/bin/bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="${SCRIPT_PATH%/*}"
if [[ "${SCRIPT_DIR}" == "${SCRIPT_PATH}" ]]; then
  SCRIPT_DIR="."
fi
SCRIPT_DIR="$(cd -- "${SCRIPT_DIR}" && pwd -P)"
PLUGIN_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)"
export PLUGIN_ROOT="${PLUGIN_ROOT}"
export CLAUDE_PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT}}"

is_caushell_repo_root() {
  local candidate="${1:-}"
  [[ -n "${candidate}" ]] &&
    [[ -f "${candidate}/Cargo.toml" ]] &&
    [[ -d "${candidate}/integrations/codex" ]]
}

repo_root="${CAUSHELL_REPO_ROOT:-}"
if ! is_caushell_repo_root "${repo_root}"; then
  if is_caushell_repo_root /opt/caushell; then
    repo_root=/opt/caushell
  elif plugin_parent_root="$(cd -- "${PLUGIN_ROOT}/../.." && pwd -P)" &&
    is_caushell_repo_root "${plugin_parent_root}"; then
    repo_root="${plugin_parent_root}"
  else
    repo_root=""
  fi
fi

if [[ -n "${repo_root}" ]]; then
  export CAUSHELL_REPO_ROOT="${repo_root}"
  if [[ -z "${CAUSHELL_CODEX_RUNTIME_PATH:-}" && -x "${repo_root}/target/debug/caushell" ]]; then
    export CAUSHELL_CODEX_RUNTIME_PATH="${repo_root}/target/debug/caushell"
  fi
  if [[ -z "${CAUSHELL_CODEX_ADAPTER_PATH:-}" && -x "${repo_root}/target/debug/caushell-adapter-codex" ]]; then
    export CAUSHELL_CODEX_ADAPTER_PATH="${repo_root}/target/debug/caushell-adapter-codex"
  fi
fi

native_hook="${CODEX_PLUGIN_OPTION_HOOK_PATH:-${CAUSHELL_CODEX_HOOK_PATH:-}}"
if [[ -z "${native_hook}" || ! -x "${native_hook}" ]] && command -v caushell-codex-hook >/dev/null 2>&1; then
  native_hook="$(command -v caushell-codex-hook)"
fi
if [[ -z "${native_hook}" || ! -x "${native_hook}" ]] &&
  [[ -n "${repo_root}" && -x "${repo_root}/target/debug/caushell-codex-hook" ]]; then
  native_hook="${repo_root}/target/debug/caushell-codex-hook"
fi

if [[ -z "${native_hook}" || ! -x "${native_hook}" ]]; then
  echo "caushell-codex: missing executable hook; set CAUSHELL_REPO_ROOT or CAUSHELL_CODEX_HOOK_PATH" >&2
  exit 1
fi

exec "${native_hook}" Status
